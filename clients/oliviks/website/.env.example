# Oliviks Kitchen environment variables
# Copy to .env.local for local development. Never commit real secrets.

# Public Supabase URL and anon key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this in client components.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only temporary guard for admin write routes until Supabase Auth is fully wired.
ADMIN_API_SECRET=

# Comma-separated owner/admin emails allowed to use /admin after auth is enabled.
ADMIN_ALLOWED_EMAILS=olivikskitchen@gmail.com

# Optional MailerLite integration, server-only.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
